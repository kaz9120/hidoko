{
	"name": "ui",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"sideEffects": [
		"**/*.css"
	],
	"exports": {
		".": "./src/index.ts",
		"./styles.css": "./src/styles.css",
		"./tokens.css": "./src/tokens.css",
		"./fonts.css": "./src/fonts.css",
		"./motion.css": "./src/motion.css",
