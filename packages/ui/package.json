{
	"name": "ui",
	"version": "0.6.0",
	"private": true,
	"type": "module",
	"sideEffects": [
		"**/*.css"
	],
	"exports": {
		".": "./src/index.ts",
		"./styles.css": "./src/styles.css",
		"./tokens.css": "./src/tokens.css",
		"./components.css": "./src/components.css",
		"./fonts.css": "./src/fonts.css",
		"./motion.css": "./src/motion.css",
		"./embers": {
			"types": "./src/embers.d.ts",
			"default": "./src/embers.js"
		},
		"./assets/*": "./assets/*",
		"./components/*": "./src/components/*.tsx",
		"./hooks/*": "./src/hooks/*.ts",
		"./lib/utils": "./src/lib/utils.ts"
	},
	"dependencies": {
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.17.0",
		"next-themes": "^0.4.6",
		"radix-ui": "^1.5.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0"
	},
	"peerDependencies": {
		"react": "^19.2.7",
		"react-dom": "^19.2.7"
	},
	"devDependencies": {
		"@storybook/react-vite": "^10.4.2",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"agentation": "^3.0.2",
		"typescript": "^6.0.3"
	},
	"scripts": {
		"typecheck": "tsc -b"
	}
}
