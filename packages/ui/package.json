		"./hooks/*": "./src/hooks/*.ts",
		"./lib/utils": "./src/lib/utils.ts"
	},
	"dependencies": {
		"@base-ui/react": "^1.5.0",
		"@hookform/resolvers": "^5.4.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"date-fns": "^4.4.0",
		"embla-carousel-react": "^8.6.0",
		"input-otp": "^1.4.2",
		"lucide-react": "^1.17.0",
		"next-themes": "^0.4.6",
		"radix-ui": "^1.5.0",
		"react-day-picker": "^9.14.0",
		"react-hook-form": "^7.78.0",
		"react-resizable-panels": "^4.11.2",
		"recharts": "3.8.1",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0",
		"vaul": "^1.1.2",
		"zod": "^4.4.3"
	},
	"peerDependencies": {
		"react": "^19.2.7",
		"react-dom": "^19.2.7"
	},
	"devDependencies": {
		"@storybook/react-vite": "^10.4.2",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"typescript": "^6.0.3"
	},
	"scripts": {
		"typecheck": "tsc -b",
