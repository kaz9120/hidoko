{
	"extends": "../../tsconfig.base.json",
	"include": [
		".storybook/**/*.ts",
		".storybook/**/*.tsx",
		"app/**/*.ts",
		"app/**/*.tsx",
		"stories/**/*.ts",
		"stories/**/*.tsx"
	],
	"exclude": ["node_modules", "storybook-static"],
	"compilerOptions": {
		"lib": ["DOM", "DOM.Iterable", "ESNext"],
		"jsx": "react-jsx",
		"types": ["vite/client"],
		"baseUrl": ".",
		"ignoreDeprecations": "6.0",
		"paths": {
			"~/*": ["./app/*"]
		}
	}
}
