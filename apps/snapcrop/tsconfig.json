{
	"extends": "../../tsconfig.base.json",
	"include": ["**/*.ts", "**/*.tsx", ".react-router/types/**/*"],
	"exclude": ["node_modules", "build", ".react-router/cache"],
	"compilerOptions": {
		"lib": ["DOM", "DOM.Iterable", "ESNext"],
		"jsx": "react-jsx",
		"types": ["vite/client"],
		"baseUrl": ".",
		"rootDirs": [".", "./.react-router/types"],
		"paths": {
			"~/*": ["./app/*"]
		}
	}
}
