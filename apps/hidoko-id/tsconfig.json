{
	"extends": "../../tsconfig.base.json",
	"include": [
		"**/*.ts",
		"**/*.tsx",
		".react-router/types/**/*",
		"worker-configuration.d.ts"
	],
	"exclude": ["node_modules", "build", ".react-router/cache"],
	"compilerOptions": {
		"lib": ["DOM", "DOM.Iterable", "ESNext"],
		"jsx": "react-jsx",
		"types": ["vite/client"],
		"baseUrl": ".",
		"rootDirs": [".", "./.react-router/types"],
		"ignoreDeprecations": "6.0",
		"paths": {
			"~/*": ["./app/*"]
		}
	}
}
