{
	"name": "hidoko-id",
	"version": "0.6.1",
	"private": true,
	"sideEffects": false,
	"type": "module",
	"scripts": {
		"build": "react-router build",
		"dev:spa": "react-router dev",
		"dev:worker": "wrangler dev",
		"dev": "concurrently -k -n spa,api -c magenta,cyan 'bun run dev:spa' 'bun run dev:worker'",
		"preview": "bun run build && vite preview",
		"deploy": "bun run build && wrangler deploy",
		"deploy:dry": "bun run build && wrangler deploy --dry-run",
		"cf-typegen": "wrangler types",
		"typegen": "react-router typegen && wrangler types",
		"typecheck": "bun run typegen && tsc -b"
	},
	"dependencies": {
		"@noble/hashes": "^2.2.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.17.0",
		"next-themes": "^0.4.6",
		"radix-ui": "^1.5.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-router": "^7.17.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0",
		"ui": "workspace:*"
	},
	"devDependencies": {
		"@react-router/dev": "^7.17.0",
		"concurrently": "^9.2.0",
		"@react-router/node": "^7.17.0",
		"@tailwindcss/vite": "^4.3.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"tailwindcss": "^4.3.0",
		"vite": "^7.3.5",
		"vite-tsconfig-paths": "^5.1.4",
		"wrangler": "^4.98.0"
	}
}
