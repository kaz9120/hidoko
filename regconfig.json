{
	"core": {
		"workingDir": ".reg",
		"actualDir": "apps/snapcrop/__screenshots__",
		"thresholdRate": 0,
		"ximgdiff": { "invocationType": "client" }
	},
	"plugins": {
		"reg-keygen-git-hash-plugin": {},
		"reg-publish-s3-plugin": {
			"bucketName": "$R2_BUCKET",
			"pathPrefix": "snapcrop",
			"sdkOptions": {
				"region": "auto",
				"endpoint": "$R2_ENDPOINT",
				"forcePathStyle": true
			}
		}
	}
}
