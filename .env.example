# Cloudflare R2 (VRT 用 / reg-suit が読む)
#
# `bunx reg-suit run` を回す前にこのファイルを `.env.local` にコピーして実値を
# 埋め、`set -a; source .env.local; set +a` などで shell に export する。
#
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY は AWS SDK v3 が自動で拾う標準名。
# R2 の S3 互換 API トークン発行画面で出てくる Access Key ID / Secret Access Key
# をそのまま入れる。
#
# R2_PUBLIC_URL は reg-suit が出す Report URL 用の公開ホスト名。R2 ダッシュボード
# でバケットの「Public R2 dev URL」を有効化して出てくる `pub-<hash>.r2.dev` を
# プロトコル (https://) **抜き** で入れる。reg-publish-s3-plugin は customDomain
# を `https://<customDomain>/...` の形で組み立てるので、`https://` を含めると
# `https://https://...` になってリンクが壊れる。これがないとデフォルトの AWS S3
# ホスト (`https://<bucket>.s3.amazonaws.com/...`) で URL を組んでしまい、
# レポートにアクセスできない。

R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_BUCKET=hidoko-vrt
R2_PUBLIC_URL=pub-<HASH>.r2.dev
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# reg-notify-github-plugin が PR コメントと Commit Status 投稿に使う GitHub App
# のクライアント ID。
# 1. https://github.com/apps/reg-suit を kaz9120/hidoko にインストール
# 2. https://reg-viz.github.io/gh-app/ で「Get client ID」を押して取得
# 3. ここに値を入れる
REG_NOTIFY_CLIENT_ID=
