# Cloudflare R2 (VRT 用 / reg-suit が読む)
#
# `bunx reg-suit run` を回す前にこのファイルを `.env.local` にコピーして実値を
# 埋め、`set -a; source .env.local; set +a` などで shell に export する。
#
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY は AWS SDK v3 が自動で拾う標準名。
# R2 の S3 互換 API トークン発行画面で出てくる Access Key ID / Secret Access Key
# をそのまま入れる。
#
# R2_PUBLIC_URL は reg-suit が出す Report URL 用の公開 URL。R2 ダッシュボードで
# バケットの「Public R2 dev URL」を有効化して出てくる `https://pub-<hash>.r2.dev`
# をそのまま入れる。これがないと reg-publish-s3-plugin はデフォルトで AWS S3
# のホスト (`https://<bucket>.s3.amazonaws.com/...`) で URL を組んでしまい、
# レポートにアクセスできない。

R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_BUCKET=hidoko-vrt
R2_PUBLIC_URL=https://pub-<HASH>.r2.dev
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
