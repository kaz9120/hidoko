# Cloudflare R2 (VRT 用 / reg-suit が読む)
#
# `bunx reg-suit run` を回す前にこのファイルを `.env.local` にコピーして実値を
# 埋め、`set -a; source .env.local; set +a` などで shell に export する。
#
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY は AWS SDK v3 が自動で拾う標準名。
# R2 の S3 互換 API トークン発行画面で出てくる Access Key ID / Secret Access Key
# をそのまま入れる。

R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_BUCKET=hidoko-vrt
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
